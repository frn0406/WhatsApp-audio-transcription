{
  "manifest_version": 3,
  "name": "Transcription Audio WhatsApp",
  "version": "1.1.0",
  "description": "Transcrit les messages vocaux de WhatsApp Web en texte (français) via Whisper (OpenAI ou Groq). Léger, sans dépendances.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://api.openai.com/*",
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Transcription Audio WhatsApp"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
